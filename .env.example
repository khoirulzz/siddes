APP_NAME="Desa Lambanggelun"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
ADMIN_LOGIN_PATH=masuk-admin
TRUSTED_PROXIES=

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lmbg_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_FOLDER_DYNAMIC=sid/dynamic
VITE_CLOUDINARY_FOLDER_ARCHIVES=sid/archives

CLOUDINARY_ENABLED=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_SECURE=true
CLOUDINARY_TIMEOUT_SECONDS=20
CLOUDINARY_FOLDER_DYNAMIC=sid/dynamic
CLOUDINARY_FOLDER_ARCHIVES=sid/archives

AI_WRITER_ENABLED=true
GEMINI=true
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_FALLBACK=
GEMINI_TIMEOUT_SECONDS=25
GEMINI_TEMPERATURE=1.0
GEMINI_MAX_OUTPUT_TOKENS=1400
OPENROUTER_ENABLED=true
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_PRIMARY=arcee-ai/trinity-mini:free
OPENROUTER_MODEL_FALLBACK=arcee-ai/trinity-large-preview:free
OPENROUTER_TIMEOUT_SECONDS=25
OPENROUTER_TEMPERATURE=0.65
OPENROUTER_MAX_TOKENS=1400
OPENROUTER_HTTP_REFERER="${APP_URL}"
OPENROUTER_X_TITLE="${APP_NAME}"
ANNOUNCEMENT_THUMBNAIL_ICON=
